{
  "expo": {
    "name": "NachoPadel",
    "slug": "NachoPadel",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/padel.png",
    "scheme": "nachopadel",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "PadelNacho",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/padel.png",
        "backgroundImage": "./assets/images/padel.png",
        "monochromeImage": "./assets/images/padel.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.nacho_06.NachoPadel"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/padel.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/padel.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow $(PRODUCT_NAME) to access your camera",
          "microphonePermission": "Allow $(PRODUCT_NAME) to access your microphone",
          "recordAudioAndroid": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true,
      "baseUrl": "/PadelMaster"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8e653571-98cf-421a-9c72-2186d3e8c040"
      }
    }
  }
}
